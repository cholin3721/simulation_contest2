				<Name>Main</Name>
				<StartupCode>com.anylogic.engine.connectivity.ResultSet rs = selectResultSet("SELECT branch_id, COUNT(*) AS cnt FROM sheet1 GROUP BY branch_id;");
try {
    while(rs.next()) {
        branchRemainingTotal.put(rs.getInt("branch_id"), rs.getInt("cnt"));
    }
} catch (Exception e) {}</StartupCode>
