									<Code>int branchId3 = slotBranches[3];
int rem3 = branchRemainingTotal.getOrDefault(branchId3, 0) - 32;
branchRemainingTotal.put(branchId3, rem3);
if (rem3 &lt;= 0) {
    completedBranches++;
    slotBranches[3] = 0;
} else {
    batchSizes[3] = min(32, rem3);
}
traceln("batch3 Out branchId=" + branchId3 + " rem=" + rem3);</Code>
