						<GenericParameterSubstitute>
							<GenericParameterSubstituteReference>
								<PackageName>com.anylogic.libraries.processmodeling</PackageName>
								<ClassName>SelectOutput5</ClassName>
								<ItemName>1412336243132</ItemName>
							</GenericParameterSubstituteReference>
						</GenericParameterSubstitute>
						<Parameters>
							<Parameter>
								<Name>type</Name>
								<Value Class="CodeValue">
									<Code>self.TYPE_EXIT_NUMBER</Code>
								</Value>
							</Parameter>
							<Parameter>
								<Name>condition1</Name>
							</Parameter>
							<Parameter>
								<Name>condition2</Name>
							</Parameter>
							<Parameter>
								<Name>condition3</Name>
							</Parameter>
							<Parameter>
								<Name>condition4</Name>
							</Parameter>
							<Parameter>
								<Name>probability1</Name>
							</Parameter>
							<Parameter>
								<Name>probability2</Name>
							</Parameter>
							<Parameter>
								<Name>probability3</Name>
							</Parameter>
							<Parameter>
								<Name>probability4</Name>
							</Parameter>
							<Parameter>
								<Name>probability5</Name>
							</Parameter>
							<Parameter>
								<Name>exitNumber</Name>
								<Value Class="CodeValue">
									<Code>((java.util.function.IntSupplier) () -&gt; {
    // 1) 기존 슬롯 탐색
    int target = -1;
    for (int i = 0; i &lt; 4; i++) {
        if (slotBranches[i] == agent.branchId) { target = i; break; }
    }

    // 2) 없으면 빈 슬롯 할당 + batchSize 초기 설정
    if (target == -1) {
        for (int i = 0; i &lt; 4; i++) {
            if (slotBranches[i] == 0) {
                slotBranches[i] = agent.branchId;
                target = i;
                int rem = branchRemainingTotal.getOrDefault(agent.branchId, 0);
                batchSizes[target] = min(32, rem);
                break;
            }
        }
    }

    // 3) 빈 슬롯도 없으면 잔여량 가장 적은 슬롯 강제 할당
    if (target == -1) {
        int minRem = Integer.MAX_VALUE;
        for (int i = 0; i &lt; 4; i++) {
            int rem = branchRemainingTotal.getOrDefault(slotBranches[i], 0);
            if (rem &lt; minRem) { minRem = rem; target = i; }
        }
    }

    agent.slotIndex = target;
    return target + 1;
}).getAsInt()
</Code>
								</Value>
